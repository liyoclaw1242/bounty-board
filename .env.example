# Bounty Board — Environment Variables
# Copy to ~/.bounty/.env and fill in your values
# chmod 600 ~/.bounty/.env

# GitHub fine-grained PAT
# Required scopes for the TARGET repo:
#   Issues: Read/Write
#   Pull requests: Read/Write
#   Contents: Read/Write
GITHUB_TOKEN=ghp_your_fine_grained_pat_here

# The repo agents will work ON (not this bounty-board repo)
# Format: owner/repo
BOUNTY_REPO=liyoclaw1242/your-target-repo

# Local path to the target repo (agents run Claude Code here)
BOUNTY_REPO_DIR=~/Projects/your-target-repo

# Optional overrides (defaults shown)
BOUNTY_DB=~/.bounty/claims.db
BOUNTY_LOG=~/.bounty/agent.log

# Agent identity (set different values when running multiple agents)
# AGENT_ID=be-1

# GitHub username of the QA bot account (to skip self-reviews)
# GITHUB_BOT_USERNAME=your-github-username
